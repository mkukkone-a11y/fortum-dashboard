<!DOCTYPE html>
<html lang="fi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Dashboard: UMM RSS &amp; Kello</title>
    <style>
        :root {
            --bg: #121212;
            --panel: #1e1e1e;
            --card: #2a2a2a;
            --card-border: #3a3a3a;
            --text: #ffffff;
            --text-dim: #a0a0a0;
            --text-faint: #666;
            --fi-blue: #00A6EF;
            --se-yellow: #FFD700;
            --green: #4CAF50;
        }

        * { box-sizing: border-box; }

        body {
            margin: 0;
            padding: 0;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background-color: var(--bg);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: var(--text);
            overflow: hidden;
        }

        .dashboard-wrapper {
            display: flex;
            flex-direction: row;
            gap: 40px;
            width: 95vw;
            max-width: 1800px;
            height: 85vh;
        }

        .clock-container, .umm-container {
            flex: 1;
            background: var(--panel);
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.6);
            padding: 40px 50px;
            display: flex;
            flex-direction: column;
            min-height: 0;
        }

        /* --- UMM-PANEELI --- */
        .umm-header-container {
            border-bottom: 2px solid #333;
            padding-bottom: 10px;
            margin-bottom: 20px;
            text-align: center;
            flex-shrink: 0;
        }

        .umm-header {
            font-size: 1.6rem;
            color: var(--text-dim);
            text-transform: uppercase;
            letter-spacing: 2px;
            margin: 0;
            font-weight: bold;
        }

        .umm-stats {
            font-size: 1rem;
            margin-top: 8px;
            color: var(--text-dim);
        }
        .umm-stats .stat-active { color: #80ff80; font-weight: bold; }
        .umm-stats .stat-upcoming { color: #66b3ff; font-weight: bold; }

        .umm-meta-row {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 12px;
            margin-top: 6px;
        }

        .umm-last-updated {
            font-size: 0.85rem;
            color: var(--text-faint);
        }

        .refresh-btn {
            background: #2a2a2a;
            border: 1px solid #444;
            color: var(--text-dim);
            border-radius: 6px;
            font-size: 0.8rem;
            padding: 4px 10px;
            cursor: pointer;
            font-family: inherit;
        }
        .refresh-btn:hover { background: #333; color: #fff; }
        .refresh-btn:focus-visible { outline: 2px solid var(--fi-blue); outline-offset: 2px; }
        .refresh-btn:disabled { opacity: 0.5; cursor: wait; }

        .error-banner {
            background-color: #4a1515;
            color: #ff8080;
            padding: 8px;
            border-radius: 4px;
            font-size: 0.9rem;
            margin-bottom: 15px;
            text-align: center;
            display: none;
            border: 1px solid #ff4d4d;
            flex-shrink: 0;
        }

        #umm-content {
            flex: 1;
            overflow-y: auto;
            padding-right: 15px;
            min-height: 0;
        }

        #umm-content::-webkit-scrollbar { width: 8px; }
        #umm-content::-webkit-scrollbar-track { background: var(--panel); }
        #umm-content::-webkit-scrollbar-thumb { background: #444; border-radius: 4px; }

        .umm-card {
            background: var(--card);
            border: 1px solid var(--card-border);
            padding: 15px 20px;
            margin-bottom: 15px;
            border-radius: 10px;
            position: relative;
        }

        .umm-card.is-new {
            border-color: var(--fi-blue);
            animation: newPulse 2s ease-in-out 3;
        }
        @keyframes newPulse {
            0%, 100% { box-shadow: none; }
            50% { box-shadow: 0 0 18px rgba(0, 166, 239, 0.55); }
        }
        @media (prefers-reduced-motion: reduce) {
            .umm-card.is-new { animation: none; }
        }

        .new-badge {
            position: absolute;
            top: -10px;
            right: 14px;
            background: var(--fi-blue);
            color: #001a26;
            font-size: 0.7rem;
            font-weight: bold;
            letter-spacing: 1px;
            padding: 3px 10px;
            border-radius: 10px;
        }

        .umm-title {
            font-weight: bold;
            font-size: 18px;
            margin-bottom: 12px;
            color: #e0e0e0;
            overflow-wrap: break-word;
            line-height: 1.4;
        }

        .umm-remarks {
            font-size: 14px;
            color: #cccccc;
            background-color: rgba(255, 255, 255, 0.05);
            padding: 10px;
            border-left: 3px solid #005293;
            border-radius: 4px;
            margin-bottom: 12px;
            font-style: italic;
            overflow-wrap: break-word;
            line-height: 1.5;
        }

        .umm-time {
            font-size: 14px;
            color: #aaa;
            margin-bottom: 12px;
            line-height: 1.5;
        }

        .progress-track {
            height: 6px;
            background: #1a1a1a;
            border-radius: 3px;
            margin-bottom: 10px;
            overflow: hidden;
            display: none;
        }
        .progress-fill {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, #2e7d32, #80ff80);
            border-radius: 3px;
            transition: width 1s linear;
        }

        .timer {
            font-weight: bold;
            font-size: 15px;
            padding: 12px;
            border-radius: 6px;
            text-align: center;
            font-variant-numeric: tabular-nums;
        }

        .timer.upcoming { background: #0f2942; color: #66b3ff; }
        .timer.warning { background: #4a1515; color: #ff8080; }
        .timer.active { background: #113311; color: #80ff80; }
        .timer.active-warning { background: #4d2600; color: #ffb366; }

        .empty-state {
            text-align: center;
            color: #888;
            font-size: 1.2rem;
            padding: 20px;
        }

        /* --- KELLOPANEELI --- */
        .clock-container {
            justify-content: center;
            align-items: center;
            gap: 40px;
        }

        .week-display {
            font-size: 1.8rem;
            color: var(--green);
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 2px;
            border-bottom: 2px solid #333;
            padding-bottom: 15px;
            width: 100%;
            text-align: center;
            margin-bottom: -10px;
        }

        .country-block {
            text-align: center;
            width: 100%;
        }

        .country-name {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 3px;
            color: var(--text-dim);
            margin-bottom: 10px;
        }

        .flag-icon {
            height: 26px;
            border-radius: 3px;
            box-shadow: 0 2px 6px rgba(0,0,0,0.4);
        }

        .time-display {
            font-weight: bold;
            font-variant-numeric: tabular-nums;
            margin-bottom: 5px;
            line-height: 1;
        }

        .date-display {
            color: #aaaaaa;
            text-transform: capitalize;
        }

        .finland .country-name { font-size: 1.5rem; }
        .finland .flag-icon { height: 32px; }
        .finland .time-display {
            font-size: clamp(4rem, 9vw, 9rem);
            color: var(--fi-blue);
            text-shadow: 0 0 30px rgba(0, 166, 239, 0.4);
        }
        .finland .date-display { font-size: 1.6rem; }

        .sweden { opacity: 0.85; }
        .sweden .country-name { font-size: 1.2rem; }
        .sweden .time-display {
            font-size: clamp(2.5rem, 5vw, 5rem);
            color: var(--se-yellow);
            text-shadow: 0 0 20px rgba(255, 215, 0, 0.3);
        }
        .sweden .date-display { font-size: 1.2rem; }

        /* --- RESPONSIIVISUUS: kapeat näytöt pinoavat paneelit --- */
        @media (max-width: 1100px) {
            body { overflow: auto; align-items: flex-start; }
            .dashboard-wrapper {
                flex-direction: column;
                height: auto;
                margin: 20px 0;
            }
            .clock-container, .umm-container {
                padding: 25px;
            }
            .umm-container { min-height: 60vh; }
            #umm-content { max-height: 60vh; }
        }
    </style>
</head>
<body>

<div class="dashboard-wrapper">

    <div class="umm-container">
        <div class="umm-header-container">
            <h2 class="umm-header">UMMIT AKTIIVISET/TULEVAT</h2>
            <div id="umm-stats" class="umm-stats"></div>
            <div class="umm-meta-row">
                <div id="last-updated" class="umm-last-updated">Ladataan tietoja...</div>
                <button id="refresh-btn" class="refresh-btn" type="button" title="Hae tiedot heti">&#8635; Päivitä</button>
            </div>
        </div>
        <div id="error-banner" class="error-banner" role="status" aria-live="polite"></div>
        <div id="umm-content"><div class="empty-state">Ladataan RSS-syötettä...</div></div>
    </div>

    <div class="clock-container">
        <div class="week-display" id="week-number">VIIKKO --</div>

        <div class="country-block finland">
            <div class="country-name">
                <svg class="flag-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 18 11" aria-hidden="true">
                    <rect width="18" height="11" fill="#ffffff"/>
                    <rect width="5" height="11" x="5" fill="#002f6c"/>
                    <rect width="18" height="3" y="4" fill="#002f6c"/>
                </svg>
                SUOMI
            </div>
            <div class="time-display" id="time-fi">--:--:--</div>
            <div class="date-display" id="date-fi">--</div>
        </div>

        <div class="country-block sweden">
            <div class="country-name">
                <svg class="flag-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 10" aria-hidden="true">
                    <rect width="16" height="10" fill="#005293"/>
                    <rect width="2" height="10" x="5" fill="#fecb00"/>
                    <rect width="16" height="2" y="4" fill="#fecb00"/>
                </svg>
                RUOTSI
            </div>
            <div class="time-display" id="time-se">--:--:--</div>
            <div class="date-display" id="date-se">--</div>
        </div>
    </div>

</div>

<script>
(function () {
    'use strict';

    /* =========================================================
       ASETUKSET
       ========================================================= */
    var CONFIG = {
        refreshIntervalMs: 300000,   // normaali päivitysväli: 5 min
        retryDelayMs: 30000,         // uudelleenyritys virheen jälkeen: 30 s
        maxRetries: 3,               // montako pikaista uudelleenyritystä ennen luovuttamista
        fetchTimeoutMs: 10000,       // yksittäisen haun aikakatkaisu
        warningWindowMs: 7200000,    // 2 h -> varoitusväri
        lookaheadDays: 7,            // näytä tapahtumat 7 pv eteenpäin
        // HUOM: Nord Poolin RSS-syötteen kellonajat ovat UTC-aikaa.
        // Muunnos Suomen aikaan tehdään Intl-rajapinnalla (huomioi kesä-/talviajan).
        feedUrl: 'https://ummrss.nordpoolgroup.com/messages/?messageTypes=5&areas=10YFI-1--------U&companies=N00290&searchText=river&publicationStartDate=2020-01-01T00%3A00%3A00.000Z&eventStartDate=2024-01-01T00%3A00%3A00.000Z&limit=100',
        rss2jsonKey: 'gclv2ea6dap5wu58f0xj4as2jaabpsv78hpxw1v6'
    };

    /* =========================================================
       APUFUNKTIOT
       ========================================================= */
    var fiDateTime = new Intl.DateTimeFormat('fi-FI', {
        timeZone: 'Europe/Helsinki',
        day: 'numeric', month: 'numeric', year: 'numeric',
        hour: '2-digit', minute: '2-digit'
    });

    function capitalizeFirstLetter(s) {
        return s.charAt(0).toUpperCase() + s.slice(1);
    }

    // ISO 8601 -viikkonumero
    function getWeekNumber(d) {
        d = new Date(Date.UTC(d.getFullYear(), d.getMonth(), d.getDate()));
        d.setUTCDate(d.getUTCDate() + 4 - (d.getUTCDay() || 7));
        var yearStart = new Date(Date.UTC(d.getUTCFullYear(), 0, 1));
        return Math.ceil((((d - yearStart) / 86400000) + 1) / 7);
    }

    // Muotoilee millisekunnit muotoon "1p 3h 12m 5s"
    function formatDuration(ms) {
        if (ms < 0) return '0h 0m 0s';
        var ts = Math.floor(ms / 1000);
        var da = Math.floor(ts / 86400);
        var h = Math.floor((ts % 86400) / 3600);
        var m = Math.floor((ts % 3600) / 60);
        var se = ts % 60;
        return (da > 0 ? da + 'p ' : '') + h + 'h ' + m + 'm ' + se + 's';
    }

    // KORJAUS AIEMPAAN: syötteen aika ("dd.mm.yyyy hh:mm") tulkitaan UTC:nä
    // ja näytetään aina Suomen aikavyöhykkeellä. Vanha koodi lisäsi kiinteästi
    // +2 h, jolloin kesäaikaan (UTC+3) kaikki ajat olivat tunnin pielessä.
    function parseNordPoolDate(str) {
        if (!str) return null;
        var parts = str.trim().split(/[\s.]+/);
        if (parts.length < 4) return null;

        var d = parseInt(parts[0], 10);
        var m = parseInt(parts[1], 10) - 1;
        var y = parseInt(parts[2], 10);
        var time = parts[3].split(':');
        var hr = parseInt(time[0], 10);
        var min = parseInt(time[1], 10);

        if ([d, m, y, hr, min].some(isNaN)) return null;
        return new Date(Date.UTC(y, m, d, hr, min, 0));
    }

    /* =========================================================
       KELLOT
       ========================================================= */
    var tOpt = { hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false };
    var dOpt = { weekday: 'short', day: 'numeric', month: 'long', year: 'numeric' };
    var fmtTimeFi = new Intl.DateTimeFormat('fi-FI', Object.assign({}, tOpt, { timeZone: 'Europe/Helsinki' }));
    var fmtDateFi = new Intl.DateTimeFormat('fi-FI', Object.assign({}, dOpt, { timeZone: 'Europe/Helsinki' }));
    var fmtTimeSe = new Intl.DateTimeFormat('fi-FI', Object.assign({}, tOpt, { timeZone: 'Europe/Stockholm' }));
    var fmtDateSe = new Intl.DateTimeFormat('fi-FI', Object.assign({}, dOpt, { timeZone: 'Europe/Stockholm' }));

    var elWeek = document.getElementById('week-number');
    var elTimeFi = document.getElementById('time-fi');
    var elDateFi = document.getElementById('date-fi');
    var elTimeSe = document.getElementById('time-se');
    var elDateSe = document.getElementById('date-se');

    function updateClocks(now) {
        elWeek.textContent = 'VIIKKO ' + getWeekNumber(now);
        elTimeFi.textContent = fmtTimeFi.format(now).replace(/\./g, ':');
        elDateFi.textContent = capitalizeFirstLetter(fmtDateFi.format(now));
        elTimeSe.textContent = fmtTimeSe.format(now).replace(/\./g, ':');
        elDateSe.textContent = capitalizeFirstLetter(fmtDateSe.format(now));
    }

    /* =========================================================
       UMM-TAPAHTUMAT
       ========================================================= */
    var ummContent = document.getElementById('umm-content');
    var errorBanner = document.getElementById('error-banner');
    var lastUpdatedEl = document.getElementById('last-updated');
    var statsEl = document.getElementById('umm-stats');
    var refreshBtn = document.getElementById('refresh-btn');

    var cachedEvents = [];      // viimeisin onnistunut haku
    var renderedCards = [];     // { ev, timerEl, progressTrack, progressFill } yhteistä ajastinta varten
    var seenEventKeys = null;   // aiemmin nähdyt tapahtumat (UUSI-merkintää varten)
    var lastSuccessTime = null;
    var retryCount = 0;
    var refreshTimeoutId = null;
    var isFetching = false;

    function eventKey(ev) {
        return ev.title + '|' + ev.start.toISOString();
    }

    // Poimii UMM-viestin HTML-taulukosta avain-arvo -parit.
    // DOMParser jäsentää HTML:n inertisti: mitään ei ladata eikä suoriteta.
    function extractEventData(descHtml) {
        var doc = new DOMParser().parseFromString(descHtml, 'text/html');
        var rows = doc.getElementsByTagName('tr');
        var data = {};
        for (var r = 0; r < rows.length; r++) {
            var th = rows[r].getElementsByTagName('th')[0];
            var td = rows[r].getElementsByTagName('td')[0];
            if (th && td) {
                var key = th.textContent.replace(':', '').trim().toLowerCase();
                data[key] = td.textContent.trim();
            }
        }
        return data;
    }

    function buildCard(ev, isNew) {
        var card = document.createElement('div');
        card.className = 'umm-card' + (isNew ? ' is-new' : '');

        if (isNew) {
            var badge = document.createElement('span');
            badge.className = 'new-badge';
            badge.textContent = 'UUSI';
            card.appendChild(badge);
        }

        var title = document.createElement('div');
        title.className = 'umm-title';
        title.textContent = ev.title;
        card.appendChild(title);

        if (ev.remarks && ev.remarks.trim().length > 0 && ev.remarks !== ev.title) {
            var remarksDiv = document.createElement('div');
            remarksDiv.className = 'umm-remarks';
            remarksDiv.textContent = ev.remarks;
            card.appendChild(remarksDiv);
        }

        var p = document.createElement('div');
        p.className = 'umm-time';
        p.textContent = 'Alkaa: ' + fiDateTime.format(ev.start) +
            (ev.end ? '  •  Päättyy: ' + fiDateTime.format(ev.end) : '');
        card.appendChild(p);

        var progressTrack = document.createElement('div');
        progressTrack.className = 'progress-track';
        var progressFill = document.createElement('div');
        progressFill.className = 'progress-fill';
        progressTrack.appendChild(progressFill);
        card.appendChild(progressTrack);

        var tmr = document.createElement('div');
        tmr.className = 'timer';
        card.appendChild(tmr);

        return { card: card, timerEl: tmr, progressTrack: progressTrack, progressFill: progressFill };
    }

    function renderEvents(events, isStale) {
        renderedCards = [];
        ummContent.innerHTML = '';

        if (isStale && lastSuccessTime) {
            errorBanner.textContent = '⚠️ Yhteyshäiriö Nord Pooliin — näytetään klo ' +
                fmtTimeFi.format(lastSuccessTime).replace(/\./g, ':') + ' haetut tiedot';
            errorBanner.style.display = 'block';
        } else if (!isStale) {
            errorBanner.style.display = 'none';
        }

        if (events.length === 0) {
            ummContent.innerHTML = '<div class="empty-state">Ei tulevia tai aktiivisia tapahtumia seuraavaan ' +
                CONFIG.lookaheadDays + ' päivään.</div>';
            updateStats(new Date());
            return;
        }

        events.forEach(function (ev) {
            var isNew = seenEventKeys !== null && !seenEventKeys.has(eventKey(ev));
            var built = buildCard(ev, isNew);
            ummContent.appendChild(built.card);
            renderedCards.push({ ev: ev, card: built.card, timerEl: built.timerEl, progressTrack: built.progressTrack, progressFill: built.progressFill });
        });

        updateTimers(new Date());
    }

    function updateStats(now) {
        var active = 0, upcoming = 0;
        cachedEvents.forEach(function (ev) {
            if (ev.start <= now && (!ev.end || ev.end > now)) active++;
            else if (ev.start > now) upcoming++;
        });
        statsEl.innerHTML = '<span class="stat-active">' + active + ' aktiivista</span> · ' +
            '<span class="stat-upcoming">' + upcoming + ' tulevaa</span>';
    }

    // Yksi yhteinen ajastin kaikille korteille (aiemmin joka kortilla oma setInterval)
    function updateTimers(now) {
        var nextEventInfo = null;

        renderedCards.forEach(function (item) {
            var ev = item.ev;
            var tmr = item.timerEl;
            var ds = ev.start - now;
            var de = ev.end ? ev.end - now : Infinity;

            if (ds > 0) {
                // Tuleva
                if (ds <= CONFIG.warningWindowMs) {
                    tmr.textContent = '⚠️ Alkaa: ' + formatDuration(ds);
                    tmr.className = 'timer warning';
                } else {
                    tmr.textContent = 'Alkaa: ' + formatDuration(ds);
                    tmr.className = 'timer upcoming';
                }
                if (!nextEventInfo || ds < nextEventInfo.ms) {
                    nextEventInfo = { ms: ds, label: 'Alkaa' };
                }
            } else if (de > 0) {
                // Aktiivinen
                if (ev.end) {
                    var total = ev.end - ev.start;
                    var pct = Math.min(100, Math.max(0, ((now - ev.start) / total) * 100));
                    item.progressTrack.style.display = 'block';
                    item.progressFill.style.width = pct.toFixed(1) + '%';
                    if (de <= CONFIG.warningWindowMs) {
                        tmr.textContent = '⚠️ AKTIIVINEN — päättyy: ' + formatDuration(de);
                        tmr.className = 'timer active-warning';
                    } else {
                        tmr.textContent = 'AKTIIVINEN — päättyy: ' + formatDuration(de);
                        tmr.className = 'timer active';
                    }
                    if (!nextEventInfo || de < nextEventInfo.ms) {
                        nextEventInfo = { ms: de, label: 'Päättyy' };
                    }
                } else {
                    tmr.textContent = 'AKTIIVINEN — ei päättymisaikaa';
                    tmr.className = 'timer active';
                }
            } else {
                // Päättynyt: piilota kortti heti (poistuu listalta seuraavassa haussa)
                item.card.style.display = 'none';
            }
        });

        updateStats(now);

        // Välilehden otsikko näyttää seuraavan tapahtuman lähtölaskennan
        if (nextEventInfo) {
            document.title = '⏳ ' + nextEventInfo.label + ' ' + formatDuration(nextEventInfo.ms) + ' — UMM Dashboard';
        } else if (renderedCards.some(function (i) { return i.ev.start <= now && (!i.ev.end || i.ev.end > now); })) {
            document.title = '🟢 Aktiivinen UMM — Dashboard';
        } else {
            document.title = 'Dashboard: UMM RSS & Kello';
        }
    }

    /* =========================================================
       RSS-HAKU + UUDELLEENYRITYS
       ========================================================= */
    function scheduleNextFetch(delayMs) {
        if (refreshTimeoutId) clearTimeout(refreshTimeoutId);
        refreshTimeoutId = setTimeout(fetchUMMRSS, delayMs);
    }

    // Aikakatkaisu ilman AbortControlleria: toimii myös hiekkalaatikoiduissa
    // ympäristöissä (esim. Clauden esikatselu), joissa AbortSignal-oliota
    // ei voi välittää fetch-kutsulle.
    function fetchWithTimeout(url, timeoutMs) {
        return new Promise(function (resolve, reject) {
            var timedOut = false;
            var timer = setTimeout(function () {
                timedOut = true;
                reject(new Error('Aikakatkaisu — palvelin ei vastannut ' + Math.round(timeoutMs / 1000) + ' sekunnissa'));
            }, timeoutMs);

            fetch(url).then(function (r) {
                clearTimeout(timer);
                if (!timedOut) resolve(r);
            }, function (err) {
                clearTimeout(timer);
                if (!timedOut) reject(err);
            });
        });
    }

    function fetchUMMRSS() {
        if (isFetching) return;
        isFetching = true;
        refreshBtn.disabled = true;

        var proxyUrl = 'https://api.rss2json.com/v1/api.json?api_key=' + CONFIG.rss2jsonKey +
            '&rss_url=' + encodeURIComponent(CONFIG.feedUrl);

        fetchWithTimeout(proxyUrl, CONFIG.fetchTimeoutMs)
            .then(function (r) {
                if (!r.ok) throw new Error('HTTP ' + r.status);
                return r.json();
            })
            .then(function (data) {
                if (data.status !== 'ok') {
                    throw new Error(data.message || 'Palvelin hylkäsi pyynnön.');
                }

                var now = new Date();
                var horizon = new Date(now.getTime() + CONFIG.lookaheadDays * 86400000);
                var processedEvents = [];

                (data.items || []).forEach(function (item) {
                    var evtData = extractEventData(item.content || item.description || '');
                    var eventStart = parseNordPoolDate(evtData['event start']);
                    var eventStop = parseNordPoolDate(evtData['event stop']);

                    if (eventStart && eventStart <= horizon && (!eventStop || eventStop > now)) {
                        var titleText = evtData['unit name'] || evtData['remarks'] || 'Yleinen UMM-ilmoitus';
                        if (titleText.length > 120) titleText = titleText.substring(0, 117) + '...';
                        processedEvents.push({
                            title: titleText,
                            remarks: evtData['remarks'] || '',
                            start: eventStart,
                            end: eventStop
                        });
                    }
                });

                processedEvents.sort(function (a, b) { return a.start - b.start; });

                cachedEvents = processedEvents;
                lastSuccessTime = now;
                retryCount = 0;

                lastUpdatedEl.textContent = 'Päivitetty: klo ' + fmtTimeFi.format(now).replace(/\./g, ':');
                renderEvents(cachedEvents, false);

                // Merkitse nykyiset tapahtumat nähdyiksi vasta renderöinnin jälkeen,
                // jotta UUSI-merkintä osuu oikeisiin kortteihin.
                seenEventKeys = new Set(processedEvents.map(eventKey));

                scheduleNextFetch(CONFIG.refreshIntervalMs);
            })
            .catch(function (e) {
                retryCount++;

                if (lastSuccessTime) {
                    renderEvents(cachedEvents, true);
                } else {
                    ummContent.innerHTML = '';
                    var errDiv = document.createElement('div');
                    errDiv.className = 'empty-state';
                    errDiv.style.color = '#ff6666';
                    errDiv.textContent = 'Virhe yhteydessä Nord Pooliin: ' + e.message +
                        (retryCount <= CONFIG.maxRetries ? ' — yritetään uudelleen ' + (CONFIG.retryDelayMs / 1000) + ' s kuluttua...' : '');
                    ummContent.appendChild(errDiv);
                }

                // Pikainen uudelleenyritys muutaman kerran, sitten normaali väli
                var delay = retryCount <= CONFIG.maxRetries ? CONFIG.retryDelayMs : CONFIG.refreshIntervalMs;
                scheduleNextFetch(delay);
            })
            .finally(function () {
                isFetching = false;
                refreshBtn.disabled = false;
            });
    }

    /* =========================================================
       KÄYNNISTYS
       ========================================================= */
    refreshBtn.addEventListener('click', fetchUMMRSS);

    // Kun välilehti palaa näkyviin ja tiedot ovat yli minuutin vanhoja, hae heti
    document.addEventListener('visibilitychange', function () {
        if (document.visibilityState === 'visible' &&
            lastSuccessTime && (Date.now() - lastSuccessTime) > 60000) {
            fetchUMMRSS();
        }
    });

    // Yksi sekuntiajastin hoitaa sekä kellot että kaikkien korttien lähtölaskennat
    setInterval(function () {
        var now = new Date();
        updateClocks(now);
        updateTimers(now);
    }, 1000);

    updateClocks(new Date());
    fetchUMMRSS();
})();
</script>

